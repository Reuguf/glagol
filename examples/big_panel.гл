создай окно "Глагол Панель 0.3" размером 760 на 760.
установи тему "тёмная".

добавь заголовок "Глагол Панель 0.3".
добавь текст "Большой тест GUI, списков, файлов, JSON, случайности и внешних переменных." как описание.

добавь поле "Имя" как имя.
добавь поле "Первое число" как первое.
добавь поле "Второе число" как второе.
добавь поле "Заметка или задача" как заметка.

добавь кнопку "Поздороваться" как кнопка_привет.
добавь кнопку "Сложить" как кнопка_плюс.
добавь кнопку "Вычесть" как кнопка_минус.
добавь кнопку "Умножить" как кнопка_умножить.
добавь кнопку "Разделить" как кнопка_делить.
добавь кнопку "Случайная идея" как кнопка_идея.
добавь кнопку "Добавить задачу" как кнопка_задача.
добавь кнопку "Показать задачи" как кнопка_показать.
добавь кнопку "Сохранить заметку" как кнопка_сохранить.
добавь кнопку "Загрузить заметку" как кнопка_загрузить.
добавь кнопку "Очистить экран" как кнопка_очистить.

добавь текст "" как результат.
добавь большой текст "" как задачи_текст.
добавь текст "" как статус.
добавь текст "" как статистика.

пусть задачи будут [].
пусть нажатий будет 0.

действие обнови_статистику:
    измени статистика на "Нажатий в приложении: " + str(нажатий).

действие плюс_нажатие:
    увеличь нажатий на 1.
    обнови_статистику().

когда нажата кнопка_привет:
    плюс_нажатие().
    если значение имя равно "":
        измени результат на "Привет, незнакомец."
    иначе:
        измени результат на "Привет, " + значение имя + ". Глагол GUI работает."
    измени статус на "Статус: приветствие выполнено."

когда нажата кнопка_плюс:
    плюс_нажатие().
    пусть а будет float(значение первое).
    пусть б будет float(значение второе).
    измени результат на "Сложение: " + str(а + б).
    измени статус на "Статус: сложение выполнено."

когда нажата кнопка_минус:
    плюс_нажатие().
    пусть а будет float(значение первое).
    пусть б будет float(значение второе).
    измени результат на "Вычитание: " + str(а - б).

когда нажата кнопка_умножить:
    плюс_нажатие().
    пусть а будет float(значение первое).
    пусть б будет float(значение второе).
    измени результат на "Умножение: " + str(а * б).

когда нажата кнопка_делить:
    плюс_нажатие().
    пусть а будет float(значение первое).
    пусть б будет float(значение второе).
    если б равно 0:
        измени результат на "Ошибка: делить на ноль нельзя."
    иначе:
        измени результат на "Деление: " + str(а / б).

когда нажата кнопка_идея:
    плюс_нажатие().
    пусть идеи будут [
        "Сделай приложение заметок на Глаголе.",
        "Сделай калькулятор с историей.",
        "Сделай генератор персонажей.",
        "Сделай мини-дневник.",
        "Сделай лаунчер своих проектов.",
        "Сделай список задач с сохранением.",
        "Сделай русскую обучалку программированию.",
        "Сделай визуальный редактор .гл файлов."
    ].
    пусть идея будет случайный элемент из идеи.
    измени результат на "Идея: " + идея.

когда нажата кнопка_задача:
    плюс_нажатие().
    если значение заметка равно "":
        измени результат на "Нельзя добавить пустую задачу."
    иначе:
        задачи.append(значение заметка).
        измени результат на "Задача добавлена."

когда нажата кнопка_показать:
    плюс_нажатие().
    если len(задачи) равно 0:
        измени задачи_текст на "Задач пока нет."
    иначе:
        пусть текст_задач будет "".
        пусть номер будет 1.
        для каждого задача из задачи:
            пусть текст_задач будет текст_задач + str(номер) + ". " + задача + "\n".
            увеличь номер на 1.
        измени задачи_текст на текст_задач.

когда нажата кнопка_сохранить:
    плюс_нажатие().
    если значение заметка равно "":
        измени результат на "Пустую заметку сохранять не буду."
    иначе:
        запиши текст значение заметка в файл "glagol_note.txt".
        измени результат на "Заметка сохранена в glagol_note.txt."

когда нажата кнопка_загрузить:
    плюс_нажатие().
    если файл существует "glagol_note.txt":
        пусть текст будет прочитай файл "glagol_note.txt".
        измени результат на "Загруженная заметка: " + текст.
    иначе:
        измени результат на "Файл glagol_note.txt пока не найден."

когда нажата кнопка_очистить:
    плюс_нажатие().
    измени результат на "".
    измени задачи_текст на "".
    измени статус на "Статус: экран очищен."

обнови_статистику().
запусти окно.
